---
import ArchiveHeader from "@components/pages/ArchiveHeader.astro";
import { LinkManifest } from "@components/pages/LinkManifest";
import StripeFooter from "@components/ui/StripeFooter.astro";
import Comments from "../components/post/Comments.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { siteConfig } from "../config";
import links from "../data/links.yml";
import Layout from "../layouts/Layout.astro";
import "../styles/cepato.css";

const navItems = [
	{ label: "Home", href: "/" },
	{ label: "Archive", href: "/archive" },
	{ label: "Friends", href: "/links" },
];

const getAvatar = (avatar: string) => {
	if (!avatar) return null;
	if (avatar.startsWith("@/assets/")) {
		return `/${avatar.replace("@/assets/", "")}`;
	}
	return avatar;
};

const linksLabel = i18n(I18nKey.links);
const pageTitle = `${linksLabel} - ${siteConfig.title}`;
const metaDescription = `${siteConfig.title} ${linksLabel}`;

const totalLinks = links.reduce((acc: any, curr: any) => acc + curr.links.length, 0);
---
<Layout title={pageTitle} description={metaDescription}>
	<div class="py-12 md:py-16 flex flex-col items-center gap-0 overflow-x-hidden pt-14">

		<ArchiveHeader
			title={i18n(I18nKey.links)}
			count={totalLinks}
			variant="dark"
		/>

		<!-- Intro Section -->
		<div class="relative w-full max-w-[840px] bg-lt-ink paper-texture shadow-2xl px-6 md:px-16 py-10 border-b border-white/10">
			<div class="absolute -top-4 -right-10 font-display text-[120px] text-lt-bg opacity-[0.03] pointer-events-none select-none uppercase">LINKS</div>
			<div class="relative z-10">
				<div class="flex items-center gap-3 mb-4">
					<div class="w-[3px] h-[10px] bg-lt-accent"></div>
					<span class="text-[11px] font-mono font-bold text-lt-bg/60 uppercase tracking-[0.2em]">Chapter_04 // Link_Exchange</span>
				</div>
				<p class="font-cn text-[14px] text-lt-bg/80 leading-relaxed max-w-2xl">
					{i18n(I18nKey.linksDescription)}
				</p>
			</div>
			<div class="absolute bottom-0 left-0 right-0 h-[3px] flex">
				<div class="bg-rl-teal w-1/3"></div>
				<div class="bg-rl-gold w-1/3"></div>
				<div class="bg-rl-red w-1/3"></div>
			</div>
		</div>

		{links.map((category: any, categoryIndex: number) => (
			<div class="relative w-full max-w-[840px] bg-lt-bg paper-texture shadow-2xl px-6 md:px-16 py-12 border-b border-lt-border/30">
				<!-- Category Header -->
				<div class="flex items-center gap-3 mb-10">
					<div class="flex items-center gap-2">
						<span class="text-[10px] font-mono font-bold text-lt-accent uppercase tracking-[0.2em]">{(categoryIndex + 1).toString().padStart(2, '0')}</span>
						<span class="text-[11px] font-mono font-semibold text-lt-ink uppercase tracking-[0.2em]">{category.title}</span>
					</div>
					<div class="flex-1 h-[1px] bg-lt-border"></div>
					<span class="text-[10px] font-mono text-lt-ghost uppercase tracking-widest">{category.links.length} Nodes</span>
				</div>

				<!-- Links Grid -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-8">
					{category.links.map((friend: any, i: number) => (
						<div class="group">
							<a 
								href={`/go/?url=${encodeURIComponent(friend.link)}`} 
								target="_blank" 
								class="block relative bg-lt-surface/30 border border-lt-border/50 p-5 hover:border-lt-accent/50 hover:bg-lt-accent/5 transition-all duration-300"
							>
								<!-- Corner decorations -->
								<div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-lt-ink/20 group-hover:border-lt-accent/50 transition-colors"></div>
								<div class="absolute top-0 right-0 w-2 h-2 border-t border-r border-lt-ink/20 group-hover:border-lt-accent/50 transition-colors"></div>
								<div class="absolute bottom-0 left-0 w-2 h-2 border-b border-l border-lt-ink/20 group-hover:border-lt-accent/50 transition-colors"></div>
								<div class="absolute bottom-0 right-0 w-2 h-2 border-b border-r border-lt-ink/20 group-hover:border-lt-accent/50 transition-colors"></div>

								<div class="flex items-start gap-4">
									<!-- Avatar -->
									<div class="relative w-14 h-14 bg-lt-surface border border-lt-border shrink-0 overflow-hidden group-hover:border-lt-accent/50 transition-colors">
										{friend.avatar ? (
											<img 
												src={getAvatar(friend.avatar)} 
												alt={friend.name}
												class="w-full h-full object-cover bg-neutral-300 transition-transform duration-300 group-hover:scale-110" 
												onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
											/>
										) : null}
										<div class="w-full h-full items-center justify-center" style={friend.avatar ? 'display:none' : 'display:flex'}>
											<svg class="w-6 h-6 text-lt-ghost" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
												<path d="M12 21a9 9 0 100-18 9 9 0 000 18z" stroke-linecap="round" stroke-linejoin="round"/>
												<path d="M12 12v6m0-6l-3-3m3 3l3-3" stroke-linecap="round" stroke-linejoin="round"/>
											</svg>
										</div>
									</div>

									<!-- Content -->
									<div class="flex-1 min-w-0">
										<h3 class="font-display text-lg text-lt-ink uppercase tracking-tight leading-none mb-2 group-hover:text-lt-accent transition-colors">
											{friend.name}
										</h3>
										<p class="font-cn text-[11px] text-lt-muted leading-relaxed line-clamp-2">
											{friend.description || i18n(I18nKey.noDescription)}
										</p>
									</div>
								</div>

								<!-- Footer -->
								<div class="mt-4 pt-3 border-t border-lt-border/30 flex justify-between items-center">
									<span class="text-[9px] font-mono text-lt-ghost uppercase tracking-widest">
										Node_{(i + 1).toString().padStart(3, '0')}
									</span>
									<span class="text-lg font-display text-lt-ink opacity-30 group-hover:opacity-100 group-hover:translate-x-1 transition-all">→</span>
								</div>
							</a>

							<!-- Copy Link Button -->
							<button 
								class="copy-link-btn mt-2 w-full py-2 border border-lt-border/30 text-[10px] font-mono uppercase tracking-widest text-lt-muted hover:bg-lt-surface hover:text-lt-ink hover:border-lt-border transition-colors"
								data-name={friend.name}
								data-url={friend.link}
								data-avatar={friend.avatar || ''}
								data-desc={friend.description || ''}
							>
								Copy_Link_Info
							</button>
							</div>
						))}
					</div>

					<StripeFooter />
				</div>
			))}

			<LinkManifest client:load />

			<Comments />

		</div>

		<!-- Copy Link Toast -->
		<div id="copy-link-toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-lt-ink text-lt-bg px-6 py-3 text-[11px] font-mono uppercase tracking-widest opacity-0 pointer-events-none transition-opacity duration-300 z-50">
			Link Info Copied
		</div>

		<script>
			// Copy link info functionality
			document.querySelectorAll('.copy-link-btn').forEach(btn => {
				btn.addEventListener('click', function() {
					const name = this.dataset.name;
					const url = this.dataset.url;
					const avatar = this.dataset.avatar;
					const desc = this.dataset.desc;

					const md = `- name: ${name}\n  link: ${url}\n  avatar: ${avatar}\n  descr: ${desc}`;
					navigator.clipboard.writeText(md).then(() => {
						const toast = document.getElementById('copy-link-toast');
						if (toast) {
							toast.classList.remove('opacity-0', 'pointer-events-none');
							toast.classList.add('opacity-100');
							setTimeout(() => {
								toast.classList.add('opacity-0', 'pointer-events-none');
								toast.classList.remove('opacity-100');
							}, 2000);
						}
					});
				});
			});
		</script>
	</div>
</Layout>